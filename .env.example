# Copy this file to `.env` and fill in real values, then restart `npm start`.
# Create React App only reads .env at startup and only exposes vars prefixed REACT_APP_.

# TMDB v4 "Read Access Token" — sent as `Authorization: Bearer <token>` (preferred).
REACT_APP_TMDB_TOKEN=

# TMDB v3 API key — used as `?api_key=` fallback (trailer hook / when no bearer token).
REACT_APP_TMDB_KEY=

# Optional: override the AI search proxy endpoint (defaults to /api/ai-search).
# The AI key itself is SERVER-SIDE only — see GROQ_KEY below.
# REACT_APP_AI_SEARCH_URL=/api/ai-search

# Optional overrides — constants.js provides working defaults if these are omitted.
# TMDB calls default to the same-origin serverless proxy at /api/tmdb (see
# api/tmdb/[...path].js), which avoids ISPs that block api.themoviedb.org.
# Set this to hit TMDB directly instead (e.g. local dev without the proxy):
# REACT_APP_TMDB_API_BASE_URL=https://api.themoviedb.org/3
# REACT_APP_TMDB_IMG_URL=https://image.tmdb.org/t/p/w500
# REACT_APP_BASE_URL=https://api.themoviedb.org/3/movie/

# --- Server-side only (Vercel project env vars; NOT prefixed REACT_APP_) ---
# Set these in the Vercel dashboard → Settings → Environment Variables.
# Used by the /api/tmdb proxy so the TMDB token stays off the client bundle.
# (If unset, the proxy falls back to the Authorization header the client sends.)
# TMDB_TOKEN=
# TMDB_KEY=
#
# Used by the /api/ai-search proxy (Groq — free, no billing card required).
# Keeps the key out of the public bundle. Get one from https://console.groq.com
# Optionally override the model with GROQ_MODEL (default: llama-3.3-70b-versatile).
# GROQ_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
